# NewVision — Environment Variables
# Copy to backend/.env and fill in values.

# Telegram
BOT_TOKEN=***
BOT_ENABLED=false

# Mini App
MINI_APP_URL=http://localhost:5173

# CORS
CORS_ORIGINS=["http://localhost:5173"]

# Database
DB_PATH=data/curtain_reader.db

# Translation (DeepSeek)
DEEPSEEK_API_KEY=***
TRANSLATION_MODEL=deepseek-chat

# Fetch
FETCH_TIMEOUT=10.0
FETCH_MAX_BYTES=10000000
