<?xml version="1.0" encoding="UTF-8"?>
<!--
  MODULE_MAP.xml — GRACE Knowledge Graph for Curtain Reader

  This file represents the module dependency graph and relationships
  between all modules in the project. It is used by AI agents for
  navigation and context retrieval.

  Update this file synchronously when modifying MODULE_CONTRACT or LINKS
  in any .py file.
-->
<MODULE_MAP version="1.0" project="curtain-reader" updated="2026-06-17">

  <!-- ============================================ -->
  <!-- PRESENTATION LAYER                           -->
  <!-- ============================================ -->

  <module name="main" layer="Presentation">
    <depends_on>config</depends_on>
    <depends_on>db</depends_on>
    <depends_on>models</depends_on>
    <depends_on>parser</depends_on>
    <depends_on>translator</depends_on>
    <depends_on>bot</depends_on>
    <file>backend/main.py</file>
  </module>

  <module name="bot" layer="Presentation">
    <depends_on>config</depends_on>
    <file>backend/bot.py</file>
  </module>

  <!-- ============================================ -->
  <!-- APPLICATION LAYER                             -->
  <!-- ============================================ -->

  <module name="parser" layer="Application">
    <depends_on>models</depends_on>
    <depends_on>config</depends_on>
    <file>backend/parser.py</file>
  </module>

  <module name="translator" layer="Application">
    <depends_on>models</depends_on>
    <depends_on>db</depends_on>
    <file>backend/translator.py</file>
  </module>

  <!-- ============================================ -->
  <!-- DOMAIN LAYER                                 -->
  <!-- ============================================ -->

  <module name="models" layer="Domain">
    <file>backend/models.py</file>
  </module>

  <!-- ============================================ -->
  <!-- DATA LAYER                                    -->
  <!-- ============================================ -->

  <module name="config" layer="Data">
    <file>backend/config.py</file>
  </module>

  <module name="db" layer="Data">
    <depends_on>models</depends_on>
    <file>backend/db.py</file>
  </module>

  <!-- ============================================ -->
  <!-- DEPENDENCY GRAPH (edges)                     -->
  <!-- ============================================ -->

  <edges>
    <!-- Presentation: main assembles the app -->
    <edge from="main" to="config" type="configures-from" />
    <edge from="main" to="db" type="initialises" />
    <edge from="main" to="bot" type="starts-polling" />
    <edge from="main" to="parser" type="calls" />
    <edge from="main" to="translator" type="calls" />
    <edge from="main" to="models" type="uses" />

    <!-- Presentation: bot reads config -->
    <edge from="bot" to="config" type="reads-settings" />

    <!-- Application → Domain: parser produces models -->
    <edge from="parser" to="models" type="produces" />
    <edge from="parser" to="config" type="reads-settings" />

    <!-- Application → Data: translator caches via db -->
    <edge from="translator" to="models" type="type-gates" />
    <edge from="translator" to="db" type="caches-through" />

    <!-- Data → Domain: db serialises models -->
    <edge from="db" to="models" type="serialises" />
  </edges>

</MODULE_MAP>
