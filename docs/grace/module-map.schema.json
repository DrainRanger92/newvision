{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "NewVision Module Map",
  "description": "JSON Schema for validating MODULE_MAP.md YAML frontmatter",
  "type": "object",
  "required": ["version", "project", "modules", "edges"],
  "properties": {
    "version": {
      "type": "string",
      "pattern": "^2\\.[0-9]+$",
      "description": "Schema version (starting at 2.0)"
    },
    "project": {
      "type": "string",
      "description": "Project identifier"
    },
    "updated": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$",
      "description": "Last update date (ISO 8601)"
    },
    "layers": {
      "type": "object",
      "description": "Layer definitions with descriptions",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "description": {"type": "string"}
        }
      }
    },
    "modules": {
      "type": "array",
      "description": "Module definitions",
      "items": {
        "type": "object",
        "required": ["name", "layer", "file"],
        "properties": {
          "name": {"type": "string"},
          "layer": {
            "type": "string",
            "enum": ["Presentation", "Application", "Domain", "Data"]
          },
          "file": {
            "type": "string",
            "pattern": "^backend/.+\\.py$"
          },
          "depends_on": {
            "type": "array",
            "items": {"type": "string"}
          },
          "responsibility": {"type": "string"},
          "contract": {"type": "string"}
        }
      }
    },
    "edges": {
      "type": "array",
      "description": "Dependency relationship edges",
      "items": {
        "type": "object",
        "required": ["from", "to", "type"],
        "properties": {
          "from": {"type": "string"},
          "to": {"type": "string"},
          "type": {"type": "string"}
        }
      }
    }
  }
}
